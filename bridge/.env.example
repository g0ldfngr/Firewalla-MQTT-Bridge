# Copy to .env and fill in your values

# MQTT broker — use tcp:// for plain, ssl:// for TLS
MQTT_BROKER=tcp://192.168.0.100:1883

# Topic prefix for all published messages
MQTT_PREFIX=firewalla

# MQTT credentials (leave blank if your broker has no auth)
MQTT_USERNAME=
MQTT_PASSWORD=

# Firewalla box IP on your LAN
FIREWALLA_IP=192.168.0.1

# How often (seconds) to poll the Firewalla API  (min 30, max 3600)
COLLECT_INTERVAL=60
